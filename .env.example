# --- SportMonks Cricket API (v2.0) ---
# Get a token at https://www.sportmonks.com/ (Cricket API).
# Docs: https://docs.sportmonks.com/v2/cricket-api
# The token is sent as the `api_token` query parameter on every request.
# Either name works; SPORTMONKS_API_TOKEN takes precedence over API_CRICKET_KEY.
SPORTMONKS_API_TOKEN=your_token_here
# API_CRICKET_KEY=your_token_here
SPORTMONKS_BASE_URL=https://cricket.sportmonks.com/api/v2.0

# DEV ONLY — set true to skip upstream TLS verification if your machine throws
# "x509: certificate signed by unknown authority". Prefer fixing the CA store.
# SPORTMONKS_INSECURE_SKIP_VERIFY=false

# --- Football: football-data.org (v4) ---
# FREE token — register at https://www.football-data.org/client/register
# Sent as the X-Auth-Token header. Football endpoints error until this is set.
# FOOTBALL_API_TOKEN=your_football_data_org_token
# FOOTBALL_BASE_URL=https://api.football-data.org/v4
# FOOTBALL_INSECURE_SKIP_VERIFY=false

# --- HTTP server ---
PORT=8090

# --- Cache ---
# Static data (standings, leagues, schedule) TTL.
CACHE_TTL=5m
# Volatile data (livescores, today's matches, scorecards) TTL.
CACHE_TTL_LIVE=20s

# --- Upstream HTTP client ---
UPSTREAM_TIMEOUT=10s
