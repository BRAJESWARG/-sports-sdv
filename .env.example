# --- Highlightly (ACTIVE provider: cricket + football) ---
# One key from https://highlightly.net/ — sent as the x-rapidapi-key header.
# Football: sports.highlightly.net/football, cricket: cricket.highlightly.net.
HIGHLIGHTLY_API_KEY=your_highlightly_key
HIGHLIGHTLY_FOOTBALL_BASE_URL=https://sports.highlightly.net/football
HIGHLIGHTLY_CRICKET_BASE_URL=https://cricket.highlightly.net
HIGHLIGHTLY_TIMEZONE=Asia/Kolkata

# --- OLD providers (commented; Highlightly replaced them) ---
# --- SportMonks Cricket API (v2.0) — token via api_token query param ---
# SPORTMONKS_API_TOKEN=your_token_here
# SPORTMONKS_BASE_URL=https://cricket.sportmonks.com/api/v2.0
# SPORTMONKS_INSECURE_SKIP_VERIFY=false
# --- Football: API-Football (api-sports.io v3) — x-apisports-key header ---
# FOOTBALL_API_TOKEN=your_api_football_key
# FOOTBALL_BASE_URL=https://v3.football.api-sports.io
# FOOTBALL_INSECURE_SKIP_VERIFY=false

# --- HTTP server ---
PORT=8090

# --- Logging ---
# JSON logs stream to stdout AND are appended to this file (dir auto-created).
# Set empty to disable the file and log to stdout only.
# LOG_FILE=logs/server.log
# Max chars of request/response bodies to log (0 = unlimited; default 2000).
# LOG_BODY_MAX=2000

# --- Cache ---
# Static data (standings, leagues, schedule) TTL.
CACHE_TTL=5m
# Volatile data (livescores, today's matches, scorecards) TTL.
CACHE_TTL_LIVE=20s

# --- Upstream HTTP client ---
UPSTREAM_TIMEOUT=10s

# --- Flights: AviationStack (https://aviationstack.com/) ---
# Sent as the access_key query param. Free plan is request-limited (~100/month).
# AVIATIONSTACK_ACCESS_KEY=your_aviationstack_key
# AVIATIONSTACK_BASE_URL=https://api.aviationstack.com/v1
